<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-07-02T00:00:00.000Z" agent="ChatGPT" version="24.0.0" type="device">
<diagram id="279e0543" name="01 Decision Overview">
  <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
    <root>
      <mxCell id="0"/>
      <mxCell id="1" parent="0"/>
      <mxCell id="p1_title" parent="1" value="WDS Metadata Consumer Architecture Decision Proposal" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#1F2937;align=center;" vertex="1"><mxGeometry x="240" y="30" width="1320" height="50" as="geometry"/></mxCell><mxCell id="p1_sub" parent="1" value="Goal: consume Kafka document events, store in WDS Inbox, process metadata with retry, audit, replay, and ECS scalability." style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#4B5563;align=center;" vertex="1"><mxGeometry x="220" y="80" width="1360" height="40" as="geometry"/></mxCell><mxCell id="ctx" parent="1" value="Context&amp;#10;&amp;#10;External systems publish document events:&amp;#10;• DocHub&amp;#10;• FileNet&amp;#10;• DMS&amp;#10;&amp;#10;WDS must create/update metadata reliably." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="80" y="170" width="360" height="190" as="geometry"/></mxCell><mxCell id="problem" parent="1" value="Problem Statement&amp;#10;&amp;#10;Kafka events must not be lost after delivery.&amp;#10;&amp;#10;Metadata update failures must be retried inside WDS with full audit trail." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="520" y="170" width="360" height="190" as="geometry"/></mxCell><mxCell id="drivers" parent="1" value="Decision Drivers&amp;#10;&amp;#10;• Reliability&amp;#10;• WDS-owned retry&amp;#10;• Audit and replay&amp;#10;• ECS scaling&amp;#10;• Low coupling&amp;#10;• Operational supportability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="960" y="170" width="360" height="190" as="geometry"/></mxCell><mxCell id="decision" parent="1" value="Selected Decision&amp;#10;&amp;#10;Use Inbox Pattern:&amp;#10;&amp;#10;1. kafka-consumer-service stores events in KAFKA_INBOX_EVENT.&amp;#10;2. wds-metadata-update-service polls Inbox and handles retry/DLQ." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="600" y="460" width="560" height="220" as="geometry"/></mxCell><mxCell id="e_ctx_prob" parent="1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6C8EBF;" edge="1" source="ctx" target="problem"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_prob_drv" parent="1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6C8EBF;" edge="1" source="problem" target="drivers"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e_drv_dec" parent="1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#82B366;" edge="1" source="drivers" target="decision"><mxGeometry relative="1" as="geometry"/></mxCell>
    </root>
  </mxGraphModel>
</diagram>
<diagram id="e5f70979" name="02 Options Comparison">
  <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
    <root>
      <mxCell id="0"/>
      <mxCell id="1" parent="0"/>
      <mxCell id="p2_title" parent="1" value="Considered Architecture Options" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#1F2937;align=center;" vertex="1"><mxGeometry x="350" y="30" width="1100" height="50" as="geometry"/></mxCell><mxCell id="opt1" parent="1" value="Option 1&amp;#10;Consumer calls Metadata Service&amp;#10;&amp;#10;Kafka → Consumer → Inbox → API/Event → Metadata Service&amp;#10;&amp;#10;Pros: separation&amp;#10;Cons: runtime dependency, harder retry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="80" y="150" width="430" height="250" as="geometry"/></mxCell><mxCell id="opt2" parent="1" value="Option 2 - Recommended&amp;#10;Inbox Pattern + Metadata Poller&amp;#10;&amp;#10;Kafka → Consumer → Inbox → Metadata Update Service&amp;#10;&amp;#10;Pros: WDS-owned retry, audit, replay, no sync dependency&amp;#10;Cons: DB polling required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="680" y="150" width="430" height="250" as="geometry"/></mxCell><mxCell id="opt3" parent="1" value="Option 3&amp;#10;Bridge / Dispatcher Service&amp;#10;&amp;#10;Kafka → Consumer → Inbox → Bridge → Metadata Service&amp;#10;&amp;#10;Pros: separates polling&amp;#10;Cons: extra service, more failure points" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1280" y="150" width="430" height="250" as="geometry"/></mxCell><mxCell id="rec" parent="1" value="Recommendation&amp;#10;&amp;#10;Choose Option 2.&amp;#10;&amp;#10;It provides the cleanest balance of reliability, simplicity, retry control, and operational support." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="550" y="560" width="700" height="180" as="geometry"/></mxCell><mxCell id="e1" parent="1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6C8EBF;" edge="1" source="opt1" target="rec"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" parent="1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#82B366;" edge="1" source="opt2" target="rec"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" parent="1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6C8EBF;" edge="1" source="opt3" target="rec"><mxGeometry relative="1" as="geometry"/></mxCell>
    </root>
  </mxGraphModel>
</diagram>
<diagram id="104138e9" name="03 Recommended Flow">
  <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
    <root>
      <mxCell id="0"/>
      <mxCell id="1" parent="0"/>
      <mxCell id="p3_title" parent="1" value="Recommended Architecture Flow" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#1F2937;align=center;" vertex="1"><mxGeometry x="420" y="30" width="960" height="50" as="geometry"/></mxCell><mxCell id="kafka" parent="1" value="Kafka Topics&amp;#10;&amp;#10;dochub.document.events&amp;#10;filenet.document.events&amp;#10;dms.document.events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="60" y="210" width="240" height="160" as="geometry"/></mxCell><mxCell id="consumer" parent="1" value="kafka-consumer-service&amp;#10;&amp;#10;• @KafkaListener&amp;#10;• Basic validation&amp;#10;• Store original event&amp;#10;• Commit Kafka offset after Inbox insert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="390" y="180" width="300" height="220" as="geometry"/></mxCell><mxCell id="inbox" parent="1" value="KAFKA_INBOX_EVENT&amp;#10;&amp;#10;EVENT_ID&amp;#10;TOPIC / PARTITION / OFFSET&amp;#10;PAYLOAD&amp;#10;STATUS&amp;#10;RETRY_COUNT&amp;#10;NEXT_RETRY_TIME" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="790" y="170" width="280" height="240" as="geometry"/></mxCell><mxCell id="processor" parent="1" value="wds-metadata-update-service&amp;#10;&amp;#10;Spring @Scheduled&amp;#10;Poll RECEIVED / RETRY&amp;#10;Lock records safely&amp;#10;Process metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1180" y="180" width="300" height="220" as="geometry"/></mxCell><mxCell id="metadata" parent="1" value="WDS Metadata DB&amp;#10;&amp;#10;Document Metadata&amp;#10;Processed Records" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1580" y="210" width="220" height="160" as="geometry"/></mxCell><mxCell id="e1" parent="1" value="Consume events" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6C8EBF;" edge="1" source="kafka" target="consumer"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" parent="1" value="Insert Inbox + Commit Offset" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#82B366;" edge="1" source="consumer" target="inbox"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" parent="1" value="Poll + Lock" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#D79B00;" edge="1" source="inbox" target="processor"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" parent="1" value="Create / Update Metadata" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#82B366;" edge="1" source="processor" target="metadata"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="note" parent="1" value="Key Principle&amp;#10;&amp;#10;After event is stored in Inbox, WDS owns processing and retry. Kafka offset can be committed safely." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="560" y="520" width="720" height="140" as="geometry"/></mxCell>
    </root>
  </mxGraphModel>
</diagram>
<diagram id="c48cdafe" name="04 Retry and DLQ">
  <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
    <root>
      <mxCell id="0"/>
      <mxCell id="1" parent="0"/>
      <mxCell id="p4_title" parent="1" value="Retry and DLQ Flow" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#1F2937;align=center;" vertex="1"><mxGeometry x="520" y="30" width="760" height="50" as="geometry"/></mxCell><mxCell id="rec" parent="1" value="Inbox Record&amp;#10;STATUS = RECEIVED / RETRY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="120" y="220" width="260" height="120" as="geometry"/></mxCell><mxCell id="proc" parent="1" value="Pick Record&amp;#10;&amp;#10;STATUS = PROCESSING&amp;#10;Set PROCESSING_NODE&amp;#10;Set LOCK_EXPIRES_AT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="500" y="200" width="290" height="160" as="geometry"/></mxCell><mxCell id="decision" parent="1" value="Metadata Update&amp;#10;Successful?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="920" y="215" width="180" height="140" as="geometry"/></mxCell><mxCell id="success" parent="1" value="SUCCESS&amp;#10;&amp;#10;STATUS = SUCCESS&amp;#10;PROCESSED_DATE = now" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1240" y="130" width="260" height="130" as="geometry"/></mxCell><mxCell id="retry" parent="1" value="Failure&amp;#10;&amp;#10;RETRY_COUNT++&amp;#10;NEXT_RETRY_TIME = future&amp;#10;STATUS = RETRY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1240" y="350" width="300" height="150" as="geometry"/></mxCell><mxCell id="dlq" parent="1" value="DLQ&amp;#10;&amp;#10;If RETRY_COUNT &gt; MAX_RETRY&amp;#10;STATUS = DLQ&amp;#10;Store error reason" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1580" y="350" width="250" height="150" as="geometry"/></mxCell><mxCell id="e1" parent="1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6C8EBF;" edge="1" source="rec" target="proc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" parent="1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6C8EBF;" edge="1" source="proc" target="decision"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" parent="1" value="Yes" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#82B366;" edge="1" source="decision" target="success"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" parent="1" value="No" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#B85450;" edge="1" source="decision" target="retry"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" parent="1" value="Retry Later" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#D79B00;" edge="1" source="retry" target="rec"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" parent="1" value="Max Retry Exceeded" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#B85450;" edge="1" source="retry" target="dlq"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="policy" parent="1" value="Recommended Retry Policy&amp;#10;&amp;#10;Attempt 1: immediate&amp;#10;Attempt 2: +30 sec&amp;#10;Attempt 3: +2 min&amp;#10;After max retry: DLQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="620" y="620" width="540" height="150" as="geometry"/></mxCell>
    </root>
  </mxGraphModel>
</diagram>
<diagram id="5cec7432" name="05 ECS Failure Recovery">
  <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
    <root>
      <mxCell id="0"/>
      <mxCell id="1" parent="0"/>
      <mxCell id="p5_title" parent="1" value="ECS Pod / Task Failure Handling" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#1F2937;align=center;" vertex="1"><mxGeometry x="460" y="30" width="880" height="50" as="geometry"/></mxCell><mxCell id="task1" parent="1" value="ECS Task 1&amp;#10;wds-metadata-update-service&amp;#10;&amp;#10;Picked Record A&amp;#10;STATUS = PROCESSING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="130" y="180" width="330" height="160" as="geometry"/></mxCell><mxCell id="inbox" parent="1" value="KAFKA_INBOX_EVENT&amp;#10;&amp;#10;PROCESSING_NODE&amp;#10;LOCKED_AT&amp;#10;LOCK_EXPIRES_AT&amp;#10;STATUS" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="700" y="160" width="280" height="200" as="geometry"/></mxCell><mxCell id="crash" parent="1" value="Task 1 Crashes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="130" y="440" width="330" height="100" as="geometry"/></mxCell><mxCell id="task2" parent="1" value="ECS Task 2&amp;#10;wds-metadata-update-service&amp;#10;&amp;#10;Find expired lock&amp;#10;Re-pick Record A" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1220" y="180" width="330" height="170" as="geometry"/></mxCell><mxCell id="rule" parent="1" value="Recovery Rule&amp;#10;&amp;#10;If STATUS = PROCESSING&amp;#10;and LOCK_EXPIRES_AT &lt; current time&amp;#10;then record is eligible for reprocessing." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="650" y="470" width="420" height="150" as="geometry"/></mxCell><mxCell id="e1" parent="1" value="Set lock" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6C8EBF;" edge="1" source="task1" target="inbox"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" parent="1" value="Runtime failure" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#B85450;" edge="1" source="task1" target="crash"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" parent="1" value="Lock expires" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#D79B00;" edge="1" source="inbox" target="rule"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" parent="1" value="Reprocess safely" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#82B366;" edge="1" source="rule" target="task2"><mxGeometry relative="1" as="geometry"/></mxCell>
    </root>
  </mxGraphModel>
</diagram>
<diagram id="ec0a8b6a" name="06 Inbox Table Design">
  <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
    <root>
      <mxCell id="0"/>
      <mxCell id="1" parent="0"/>
      <mxCell id="p6_title" parent="1" value="KAFKA_INBOX_EVENT Table Design" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#1F2937;align=center;" vertex="1"><mxGeometry x="420" y="30" width="960" height="50" as="geometry"/></mxCell><mxCell id="table" parent="1" value="KAFKA_INBOX_EVENT

INBOX_ID - WDS generated primary key
EVENT_ID - Business event id from payload
CORRELATION_ID - Trace id
SOURCE_SYSTEM - Derived from topic
EVENT_TYPE - Parsed from payload
TOPIC_NAME - Kafka metadata
PARTITION_NO - Kafka metadata
OFFSET_NO - Kafka metadata
DOCUMENT_ID - Parsed from payload
PAYLOAD - Original Kafka message
STATUS - RECEIVED / PROCESSING / SUCCESS / RETRY / DLQ
RETRY_COUNT - Retry attempts
MAX_RETRY - Maximum retry limit
NEXT_RETRY_TIME - Retry eligibility
PROCESSING_NODE - ECS task id
LOCKED_AT - Lock start time
LOCK_EXPIRES_AT - Lock timeout
ERROR_MESSAGE - Failure reason
RECEIVED_DATE - Listener received time
PROCESSED_DATE - Completed time
CREATED_DATE / UPDATED_DATE - Audit fields" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="300" y="130" width="1200" height="700" as="geometry"/></mxCell><mxCell id="idx" parent="1" value="Recommended Unique Index&amp;#10;&amp;#10;(EVENT_ID, SOURCE_SYSTEM)&amp;#10;&amp;#10;or fallback unique key:&amp;#10;(TOPIC_NAME, PARTITION_NO, OFFSET_NO)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="560" y="890" width="700" height="140" as="geometry"/></mxCell>
    </root>
  </mxGraphModel>
</diagram>
</mxfile>