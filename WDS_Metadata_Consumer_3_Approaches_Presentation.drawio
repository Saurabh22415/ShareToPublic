<diagram id="eadfbc731a" name="WDS Metadata Consumer - 3 Approaches">
<mxGraphModel dx="2300" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" page="1" pageScale="1" pageWidth="2300" pageHeight="1400">
<root>
<mxCell id="0"/>
<mxCell id="1" parent="0"/>
<mxCell id="title" parent="1" value="WDS - METADATA-CONSUMER SERVICE - 3 APPROACHES" style="text;html=1;strokeColor=none;fillColor=none;fontSize=34;fontStyle=1;fontColor=#0B1F5B;align=center;" vertex="1"><mxGeometry x="300" y="15" width="1700" height="55" as="geometry"/></mxCell><mxCell id="subtitle" parent="1" value="Goal: Consume events from Kafka and update WDS metadata with reliability, retry, audit, DLQ, and monitoring." style="text;html=1;strokeColor=none;fillColor=none;fontSize=16;fontColor=#374151;align=center;" vertex="1"><mxGeometry x="280" y="72" width="1740" height="35" as="geometry"/></mxCell><mxCell id="sec1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#15803D;strokeWidth=2;" vertex="1"><mxGeometry x="25" y="120" width="2250" height="330" as="geometry"/></mxCell><mxCell id="sec2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#1D4ED8;strokeWidth=2;" vertex="1"><mxGeometry x="25" y="470" width="2250" height="345" as="geometry"/></mxCell><mxCell id="sec3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#6D28D9;strokeWidth=2;" vertex="1"><mxGeometry x="25" y="835" width="2250" height="350" as="geometry"/></mxCell><mxCell id="n1" parent="1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#15803D;strokeColor=#15803D;fontColor=#FFFFFF;fontSize=22;fontStyle=1;" vertex="1"><mxGeometry x="38" y="135" width="46" height="46" as="geometry"/></mxCell><mxCell id="h1" parent="1" value="APPROACH 1 : wds-metadata-consumer (Direct Consumer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#15803D;strokeColor=#15803D;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" vertex="1"><mxGeometry x="95" y="137" width="710" height="38" as="geometry"/></mxCell><mxCell id="n2" parent="1" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1D4ED8;fontColor=#FFFFFF;fontSize=22;fontStyle=1;" vertex="1"><mxGeometry x="38" y="485" width="46" height="46" as="geometry"/></mxCell><mxCell id="h2" parent="1" value="APPROACH 2 : wds-Kafka-consumer + wds-metadata-Update (Inbox Pattern)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1D4ED8;strokeColor=#1D4ED8;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" vertex="1"><mxGeometry x="95" y="487" width="930" height="38" as="geometry"/></mxCell><mxCell id="n3" parent="1" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6D28D9;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=22;fontStyle=1;" vertex="1"><mxGeometry x="38" y="850" width="46" height="46" as="geometry"/></mxCell><mxCell id="h3" parent="1" value="APPROACH 3 : wds-Kafka-consumer + wds-kafka-trigger-event + wds-metadata-Update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6D28D9;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" vertex="1"><mxGeometry x="95" y="852" width="1120" height="38" as="geometry"/></mxCell><mxCell id="a1_kafka" parent="1" value="Kafka Topic&amp;#10;wds.document.events" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#F3E8FF;strokeColor=#7E22CE;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="55" y="230" width="180" height="115" as="geometry"/></mxCell><mxCell id="a1_service" parent="1" value="wds-metadata-consumer Service&amp;#10;(Spring Boot)&amp;#10;&amp;#10;Kafka Consumer → Business Processor → Metadata Update Client&amp;#10;&amp;#10;Retry + Error Handling + DLQ Producer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="380" y="190" width="590" height="210" as="geometry"/></mxCell><mxCell id="a1_meta" parent="1" value="Metadata Systems&amp;#10;&amp;#10;WDS DB / External Systems" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFFFFF;strokeColor=#6C8EBF;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="1115" y="230" width="240" height="120" as="geometry"/></mxCell><mxCell id="a1_dlq" parent="1" value="DLQ Topic&amp;#10;wds.document.events.DLQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="790" y="410" width="270" height="60" as="geometry"/></mxCell><mxCell id="a1_tech" parent="1" value="TECHNOLOGIES&amp;#10;&amp;#10;✅ Spring Boot&amp;#10;✅ Spring Kafka @KafkaListener&amp;#10;✅ Resilience4j&amp;#10;✅ Kafka DLQ Topic&amp;#10;✅ JDBC / JPA / REST Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="1445" y="170" width="320" height="240" as="geometry"/></mxCell><mxCell id="a1_pc" parent="1" value="PROS&amp;#10;✅ Simple architecture&amp;#10;✅ Low latency direct processing&amp;#10;✅ Fewer components to manage&amp;#10;✅ Easy to develop/deploy&amp;#10;&amp;#10;CONS&amp;#10;❌ Tight coupling of consume + process&amp;#10;❌ Scaling limited to consumer instances&amp;#10;❌ Slow processing affects consumption&amp;#10;❌ Harder to reprocess selected events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="1840" y="165" width="390" height="260" as="geometry"/></mxCell><mxCell id="a1e1" parent="1" value="Consume" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#15803D;" edge="1" source="a1_kafka" target="a1_service"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a1e2" parent="1" value="Update" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#15803D;" edge="1" source="a1_service" target="a1_meta"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a1e3" parent="1" value="On Failure" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#DC2626;dashed=1;" edge="1" source="a1_service" target="a1_dlq"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a2_kafka" parent="1" value="Kafka Topic&amp;#10;wds.document.events" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#F3E8FF;strokeColor=#7E22CE;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="55" y="590" width="170" height="105" as="geometry"/></mxCell><mxCell id="a2_cons" parent="1" value="wds-Kafka-consumer Service&amp;#10;(Spring Boot)&amp;#10;&amp;#10;Kafka Consumer → Inbox Writer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="320" y="560" width="280" height="140" as="geometry"/></mxCell><mxCell id="a2_inbox" parent="1" value="KAFKA_INBOX_EVENT&amp;#10;(Inbox Table)&amp;#10;&amp;#10;INBOX_ID, EVENT_ID&amp;#10;PAYLOAD&amp;#10;STATUS: RECEIVED / PROCESSING / RETRY / SUCCESS / DLQ&amp;#10;RETRY_COUNT, NEXT_RETRY_TIME&amp;#10;LOCKED_AT, LOCK_EXPIRES_AT&amp;#10;ERROR_MESSAGE, CREATED_AT" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="690" y="535" width="300" height="205" as="geometry"/></mxCell><mxCell id="a2_update" parent="1" value="wds-metadata-Update Service&amp;#10;(Spring Boot Scheduled Poller)&amp;#10;&amp;#10;Inbox Poller → Business Processor → Metadata Update Client&amp;#10;&amp;#10;Retry Logic + DLQ Handling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="1100" y="535" width="440" height="210" as="geometry"/></mxCell><mxCell id="a2_meta" parent="1" value="WDS Metadata DB" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFFFFF;strokeColor=#6C8EBF;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="1640" y="585" width="190" height="120" as="geometry"/></mxCell><mxCell id="a2_dlq" parent="1" value="DLQ Topic&amp;#10;wds.document.events.DLQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="1310" y="755" width="260" height="55" as="geometry"/></mxCell><mxCell id="a2_tech" parent="1" value="TECHNOLOGIES&amp;#10;&amp;#10;✅ Spring Boot&amp;#10;✅ Spring Kafka&amp;#10;✅ Spring Scheduler @Scheduled&amp;#10;✅ JPA / Hibernate&amp;#10;✅ Oracle / PostgreSQL&amp;#10;✅ Kafka DLQ&amp;#10;✅ HikariCP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="1600" y="495" width="270" height="250" as="geometry"/></mxCell><mxCell id="a2_pc" parent="1" value="PROS&amp;#10;✅ Decouples consume and process&amp;#10;✅ Reliable DB persisted events&amp;#10;✅ Easy retry and reprocessing&amp;#10;✅ Better control and monitoring&amp;#10;✅ Can replay/reprocess events&amp;#10;&amp;#10;CONS&amp;#10;❌ More components&amp;#10;❌ Higher latency due to polling interval&amp;#10;❌ Requires DB locking and cleanup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="1900" y="495" width="330" height="250" as="geometry"/></mxCell><mxCell id="a2e1" parent="1" value="Consume" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#1D4ED8;" edge="1" source="a2_kafka" target="a2_cons"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a2e2" parent="1" value="Insert" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#1D4ED8;" edge="1" source="a2_cons" target="a2_inbox"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a2e3" parent="1" value="Poll / Fetch" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#1D4ED8;" edge="1" source="a2_inbox" target="a2_update"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a2e4" parent="1" value="Update" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#1D4ED8;" edge="1" source="a2_update" target="a2_meta"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a2e5" parent="1" value="On Failure" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#DC2626;dashed=1;" edge="1" source="a2_update" target="a2_dlq"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a3_kafka" parent="1" value="Kafka Topic&amp;#10;wds.document.events" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#F3E8FF;strokeColor=#7E22CE;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="55" y="965" width="165" height="105" as="geometry"/></mxCell><mxCell id="a3_cons" parent="1" value="wds-Kafka-consumer Service&amp;#10;(Spring Boot)&amp;#10;&amp;#10;Kafka Consumer → Inbox Writer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="270" y="950" width="270" height="130" as="geometry"/></mxCell><mxCell id="a3_inbox" parent="1" value="KAFKA_INBOX_EVENT&amp;#10;(Inbox Table)&amp;#10;&amp;#10;INBOX_ID, EVENT_ID&amp;#10;PAYLOAD&amp;#10;STATUS: RECEIVED / PROCESSING / RETRY / SUCCESS / DLQ&amp;#10;RETRY_COUNT, NEXT_RETRY_TIME&amp;#10;LOCKED_AT, LOCK_EXPIRES_AT&amp;#10;ERROR_MESSAGE, CREATED_AT" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="610" y="915" width="290" height="205" as="geometry"/></mxCell><mxCell id="a3_trigger" parent="1" value="wds-kafka-trigger-event Service&amp;#10;(Trigger / Notifier)&amp;#10;&amp;#10;Inbox Monitor → Event Publisher&amp;#10;&amp;#10;Techniques:&amp;#10;• DB Change Capture / Timestamp&amp;#10;• DB Trigger / CDC&amp;#10;• Lightweight Poller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="990" y="915" width="330" height="225" as="geometry"/></mxCell><mxCell id="a3_update" parent="1" value="wds-metadata-Update Service&amp;#10;(On-Demand / Async)&amp;#10;&amp;#10;Business Processor → Metadata Update Client&amp;#10;&amp;#10;Retry Logic + DLQ Handling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="1410" y="925" width="320" height="190" as="geometry"/></mxCell><mxCell id="a3_meta" parent="1" value="WDS Metadata DB" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFFFFF;strokeColor=#6C8EBF;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="1800" y="965" width="175" height="105" as="geometry"/></mxCell><mxCell id="a3_dlq" parent="1" value="DLQ Topic&amp;#10;wds.document.events.DLQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontSize=13;fontStyle=1;" vertex="1"><mxGeometry x="1510" y="1135" width="260" height="55" as="geometry"/></mxCell><mxCell id="a3_tech" parent="1" value="TECHNOLOGIES&amp;#10;&amp;#10;✅ Spring Boot&amp;#10;✅ Spring Kafka&amp;#10;✅ Scheduler / Trigger&amp;#10;✅ JPA / Hibernate&amp;#10;✅ DB / CDC Optional&amp;#10;✅ Kafka DLQ&amp;#10;✅ Resilience4j" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="1785" y="870" width="245" height="250" as="geometry"/></mxCell><mxCell id="a3_pc" parent="1" value="PROS&amp;#10;✅ Near real-time trigger-based flow&amp;#10;✅ Scalable and decoupled&amp;#10;✅ No constant polling in update service&amp;#10;✅ Better throughput&amp;#10;✅ Good for high volume&amp;#10;&amp;#10;CONS&amp;#10;❌ More components&amp;#10;❌ Complex to implement&amp;#10;❌ Harder monitoring/troubleshooting&amp;#10;❌ Needs trigger/CDC mechanism" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="2050" y="870" width="220" height="250" as="geometry"/></mxCell><mxCell id="a3e1" parent="1" value="Consume" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6D28D9;" edge="1" source="a3_kafka" target="a3_cons"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a3e2" parent="1" value="Insert" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6D28D9;" edge="1" source="a3_cons" target="a3_inbox"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a3e3" parent="1" value="Trigger" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6D28D9;" edge="1" source="a3_inbox" target="a3_trigger"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a3e4" parent="1" value="Invoke" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6D28D9;" edge="1" source="a3_trigger" target="a3_update"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a3e5" parent="1" value="Update" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#6D28D9;" edge="1" source="a3_update" target="a3_meta"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="a3e6" parent="1" value="On Failure" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#DC2626;dashed=1;" edge="1" source="a3_update" target="a3_dlq"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="summary" parent="1" value="COMPARISON SUMMARY&amp;#10;&amp;#10;Approach 1 Direct Consumer: Low components, low latency, low complexity, but tighter coupling. Best for simple / low-volume cases.&amp;#10;&amp;#10;Approach 2 Inbox Pattern: Medium components, reliable, better monitoring, replay, retry control. Best for most enterprise WDS use cases.&amp;#10;&amp;#10;Approach 3 Trigger Based: High components, near real-time, scalable, but complex. Best for high-volume / low-latency future state." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="35" y="1210" width="1060" height="150" as="geometry"/></mxCell><mxCell id="patterns" parent="1" value="COMMON PATTERNS&amp;#10;&amp;#10;📌 Inbox Pattern&amp;#10;🔁 Retry with Exponential Backoff&amp;#10;🧪 DLQ for Failed Events&amp;#10;🔒 Idempotent Processing&amp;#10;⏱ Lock + Expiry for Safe Retry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="1120" y="1210" width="430" height="150" as="geometry"/></mxCell><mxCell id="notes" parent="1" value="NOTES&amp;#10;&amp;#10;• All approaches should use DLQ for poison message handling.&amp;#10;• EVENT_ID should be used as idempotency key.&amp;#10;• Monitoring with CloudWatch / Prometheus / Grafana.&amp;#10;• Tracing with OpenTelemetry is recommended.&amp;#10;• Approach 2 is recommended for Phase 1 enterprise implementation." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#CBD5E1;shadow=1;fontSize=13;" vertex="1"><mxGeometry x="1580" y="1210" width="680" height="150" as="geometry"/></mxCell>
</root>
</mxGraphModel>
</diagram>
</mxfile>