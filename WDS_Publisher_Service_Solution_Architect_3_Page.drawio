<mxCell id="t" parent="1" value="Approach 1 - Outbox Pattern with Fixed Scheduler" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;fontColor=#0B2545;align=center;" vertex="1"><mxGeometry x="220" y="25" width="1360" height="50" as="geometry"/></mxCell><mxCell id="s" parent="1" value="Recommended Phase 1: WDS controls publishing, retry, status, DLQ, and monitoring." style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#4B5563;align=center;" vertex="1"><mxGeometry x="260" y="78" width="1280" height="30" as="geometry"/></mxCell><mxCell id="lane" parent="1" value="APPROACH 1 - Scheduled Poller Publisher" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FFF4;strokeColor=#2F855A;strokeWidth=2;fontSize=14;" vertex="1"><mxGeometry x="30" y="115" width="1740" height="830" as="geometry"/></mxCell><mxCell id="app" parent="1" value="1. WDS Application&amp;#10;&amp;#10;Insert Outbox Event&amp;#10;STATUS = PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="70" y="230" width="220" height="160" as="geometry"/></mxCell><mxCell id="table" parent="1" value="2. Kafka_Outbox_Event Table&amp;#10;&amp;#10;PENDING - ready to publish&amp;#10;PROCESSING - picked by publisher&amp;#10;SUCCESS - published successfully&amp;#10;FAILED - failed after max retry" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="380" y="190" width="300" height="250" as="geometry"/></mxCell><mxCell id="pub" parent="1" value="3. wds-publisher-service&amp;#10;(Spring Boot Scheduled Poller)&amp;#10;&amp;#10;① Poll PENDING events&amp;#10;② FOR UPDATE SKIP LOCKED&amp;#10;③ Mark PROCESSING&amp;#10;④ Publish to Kafka&amp;#10;⑤ Update status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="770" y="175" width="330" height="280" as="geometry"/></mxCell><mxCell id="kafka" parent="1" value="4. Kafka Topic&amp;#10;&amp;#10;wds.document.events" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#EDE9FE;strokeColor=#7C3AED;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1210" y="230" width="210" height="160" as="geometry"/></mxCell><mxCell id="down" parent="1" value="5. Downstream Consumers&amp;#10;&amp;#10;Metadata Consumer&amp;#10;Other future consumers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1510" y="230" width="220" height="160" as="geometry"/></mxCell><mxCell id="retry" parent="1" value="Retry Logic&amp;#10;&amp;#10;Increment RETRY_COUNT&amp;#10;Calculate NEXT_RETRY_TIME&amp;#10;Exponential backoff&amp;#10;Keep STATUS = PENDING/RETRY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="760" y="560" width="320" height="160" as="geometry"/></mxCell><mxCell id="dlq" parent="1" value="Publisher DLQ / Failed Records&amp;#10;&amp;#10;STATUS = FAILED&amp;#10;Optional: wds.publisher.dlq&amp;#10;Alert Operations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1180" y="560" width="300" height="160" as="geometry"/></mxCell><mxCell id="monitor" parent="1" value="Monitoring&amp;#10;&amp;#10;CloudWatch / Splunk&amp;#10;Pending count&amp;#10;Failed count&amp;#10;Publish latency" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1530" y="560" width="220" height="160" as="geometry"/></mxCell><mxCell id="pros" parent="1" value="Pros&amp;#10;✅ Simple implementation&amp;#10;✅ Full WDS retry control&amp;#10;✅ Easy support and monitoring&amp;#10;✅ Kafka outage safe" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="80" y="650" width="290" height="190" as="geometry"/></mxCell><mxCell id="cons" parent="1" value="Cons&amp;#10;⚠ DB polling&amp;#10;⚠ Small scheduler latency&amp;#10;⚠ Need cleanup/archive&amp;#10;⚠ Need locking logic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="400" y="650" width="290" height="190" as="geometry"/></mxCell><mxCell id="e1" parent="1" value="Insert" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2F855A;" edge="1" source="app" target="table"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" parent="1" value="Poll" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2F855A;" edge="1" source="table" target="pub"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" parent="1" value="Publish success" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2F855A;" edge="1" source="pub" target="kafka"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" parent="1" value="Consume" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2F855A;" edge="1" source="kafka" target="down"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" parent="1" value="Publish failure" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#C53030;dashed=1;" edge="1" source="pub" target="retry"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" parent="1" value="Retry later" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#D69E2E;dashed=1;" edge="1" source="retry" target="table"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" parent="1" value="Max retry exceeded" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#C53030;dashed=1;" edge="1" source="retry" target="dlq"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e8" parent="1" value="Alert" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#C53030;dashed=1;" edge="1" source="dlq" target="monitor"><mxGeometry relative="1" as="geometry"/></mxCell>
