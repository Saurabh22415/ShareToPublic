<mxCell id="t" parent="1" value="WDS Publisher Service Architecture Overview" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;fontColor=#0B2545;align=center;" vertex="1"><mxGeometry x="260" y="25" width="1280" height="50" as="geometry"/></mxCell><mxCell id="s" parent="1" value="Solution Architect View: two reliable producer options for publishing WDS document events to Kafka." style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#4B5563;align=center;" vertex="1"><mxGeometry x="270" y="78" width="1260" height="30" as="geometry"/></mxCell><mxCell id="aws" parent="1" value="AWS / Enterprise Event Platform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2B6CB0;strokeWidth=2;fontSize=14;" vertex="1"><mxGeometry x="40" y="120" width="1720" height="760" as="geometry"/></mxCell><mxCell id="app" parent="1" value="WDS Application / Services&amp;#10;&amp;#10;Document Created&amp;#10;Document Updated&amp;#10;Document Deleted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="90" y="300" width="230" height="170" as="geometry"/></mxCell><mxCell id="db" parent="1" value="WDS Database&amp;#10;&amp;#10;Business Tables&amp;#10;+&amp;#10;Kafka_Outbox_Event" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="410" y="285" width="230" height="200" as="geometry"/></mxCell><mxCell id="choice" parent="1" value="Producer Approach Decision" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="735" y="305" width="250" height="155" as="geometry"/></mxCell><mxCell id="sch" parent="1" value="Approach 1&amp;#10;Outbox + Fixed Scheduler&amp;#10;&amp;#10;Spring @Scheduled&amp;#10;KafkaTemplate&amp;#10;Application retry/DLQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1080" y="190" width="280" height="210" as="geometry"/></mxCell><mxCell id="cdc" parent="1" value="Approach 2&amp;#10;Outbox + CDC&amp;#10;&amp;#10;Debezium / Kafka Connect&amp;#10;DB transaction log&amp;#10;Connector retry/DLQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1080" y="530" width="280" height="210" as="geometry"/></mxCell><mxCell id="topic" parent="1" value="Kafka Topic&amp;#10;&amp;#10;wds.document.events" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#EDE9FE;strokeColor=#7C3AED;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1480" y="335" width="190" height="160" as="geometry"/></mxCell><mxCell id="cons" parent="1" value="Downstream Consumers&amp;#10;&amp;#10;Metadata Consumer&amp;#10;Audit Consumer&amp;#10;Future Consumers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1480" y="560" width="220" height="170" as="geometry"/></mxCell><mxCell id="reco" parent="1" value="Recommended Phase 1&amp;#10;&amp;#10;Use Approach 1: Outbox + Fixed Scheduler&amp;#10;&amp;#10;Reason: simpler, WDS-controlled retry, easier support." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7FAFC;strokeColor=#CBD5E0;shadow=1;fontSize=12;" vertex="1"><mxGeometry x="500" y="700" width="560" height="110" as="geometry"/></mxCell><mxCell id="e1" parent="1" value="Same DB transaction" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2F855A;" edge="1" source="app" target="db"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" parent="1" value="Reliable event source" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2B6CB0;" edge="1" source="db" target="choice"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" parent="1" value="Option 1" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2F855A;" edge="1" source="choice" target="sch"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" parent="1" value="Option 2" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2B6CB0;" edge="1" source="choice" target="cdc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" parent="1" value="Publish" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2F855A;" edge="1" source="sch" target="topic"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" parent="1" value="Publish" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2B6CB0;" edge="1" source="cdc" target="topic"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" parent="1" value="Consume" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2B6CB0;" edge="1" source="topic" target="cons"><mxGeometry relative="1" as="geometry"/></mxCell>
