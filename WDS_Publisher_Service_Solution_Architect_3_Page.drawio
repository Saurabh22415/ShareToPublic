<mxCell id="t" parent="1" value="Approach 2 - Outbox Pattern with CDC" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;fontColor=#0B2545;align=center;" vertex="1"><mxGeometry x="260" y="25" width="1280" height="50" as="geometry"/></mxCell><mxCell id="s" parent="1" value="Future-state option: platform-managed CDC using Debezium/Kafka Connect." style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#4B5563;align=center;" vertex="1"><mxGeometry x="280" y="78" width="1240" height="30" as="geometry"/></mxCell><mxCell id="lane" parent="1" value="APPROACH 2 - Transactional Outbox + Debezium CDC Publisher" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2B6CB0;strokeWidth=2;fontSize=14;" vertex="1"><mxGeometry x="30" y="115" width="1740" height="830" as="geometry"/></mxCell><mxCell id="app" parent="1" value="1. WDS Application&amp;#10;&amp;#10;Insert Business Data&amp;#10;+ Outbox Event&amp;#10;Same DB transaction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="70" y="230" width="230" height="170" as="geometry"/></mxCell><mxCell id="table" parent="1" value="2. Kafka_Outbox_Event Table&amp;#10;(Transactional Outbox)&amp;#10;&amp;#10;Event stored in DB&amp;#10;Captured through DB log" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="390" y="210" width="260" height="210" as="geometry"/></mxCell><mxCell id="log" parent="1" value="3. Database Transaction Log&amp;#10;&amp;#10;Redo / WAL / Binlog&amp;#10;CDC source of truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="740" y="230" width="250" height="170" as="geometry"/></mxCell><mxCell id="cdc" parent="1" value="4. Debezium / Kafka Connect&amp;#10;&amp;#10;① Capture DB log changes&amp;#10;② Transform Outbox record&amp;#10;③ Publish to Kafka&amp;#10;④ Retry connector failures" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1080" y="190" width="330" height="250" as="geometry"/></mxCell><mxCell id="kafka" parent="1" value="5. Kafka Topic&amp;#10;&amp;#10;wds.document.events" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#EDE9FE;strokeColor=#7C3AED;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1510" y="230" width="210" height="160" as="geometry"/></mxCell><mxCell id="dlq" parent="1" value="CDC DLQ Topic&amp;#10;&amp;#10;wds.publisher.dlq&amp;#10;Invalid payload&amp;#10;Connector failure&amp;#10;Transform error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1090" y="560" width="310" height="170" as="geometry"/></mxCell><mxCell id="monitor" parent="1" value="Platform Monitoring&amp;#10;&amp;#10;Connector status&amp;#10;Connector lag&amp;#10;DLQ size&amp;#10;Kafka auth/cert errors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="1490" y="560" width="260" height="170" as="geometry"/></mxCell><mxCell id="pros" parent="1" value="Pros&amp;#10;✅ Near real-time&amp;#10;✅ No app scheduler&amp;#10;✅ High throughput&amp;#10;✅ Less custom code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="80" y="650" width="290" height="180" as="geometry"/></mxCell><mxCell id="cons" parent="1" value="Cons&amp;#10;⚠ More infra complexity&amp;#10;⚠ Debezium/Kafka Connect needed&amp;#10;⚠ DB log access required&amp;#10;⚠ Harder troubleshooting&amp;#10;⚠ DB log retention risk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;shadow=1;fontStyle=1;fontSize=13;" vertex="1"><mxGeometry x="400" y="650" width="320" height="180" as="geometry"/></mxCell><mxCell id="e1" parent="1" value="Same DB transaction" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2B6CB0;" edge="1" source="app" target="table"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" parent="1" value="DB writes log" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2B6CB0;" edge="1" source="table" target="log"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" parent="1" value="CDC reads log" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2B6CB0;" edge="1" source="log" target="cdc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" parent="1" value="Publish success" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#2B6CB0;" edge="1" source="cdc" target="kafka"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" parent="1" value="Connector failure" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#C53030;dashed=1;" edge="1" source="cdc" target="dlq"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" parent="1" value="Alert / monitor" style="endArrow=block;html=1;rounded=1;strokeWidth=2;fontSize=12;strokeColor=#C53030;dashed=1;" edge="1" source="dlq" target="monitor"><mxGeometry relative="1" as="geometry"/></mxCell>
